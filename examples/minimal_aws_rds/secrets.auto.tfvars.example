# Copy to secrets.auto.tfvars and fill in real values.
# secrets.auto.tfvars is gitignored — never commit secrets.

# SSH public key for EC2 instance access (required for compute_engine=ec2)
ssh_public_key = "ssh-ed25519 AAAA..."
ec2_ssh_private_key_path = "~/.ssh/id_X"

# Optional: override auto-resolved RPC URL (defaults to http://erpc:4000 when rpc_proxy is enabled)
# indexer_rpc_url = "https://eth-mainnet.g.alchemy.com/v2/your-api-key"
