# Copy to secrets.auto.tfvars and fill in real values.
# secrets.auto.tfvars is gitignored — never commit secrets.

# Bare metal VPS
bare_metal_host = "100.0.0.0.0"
# bare_metal_ssh_user = "ubuntu"     # default
# bare_metal_ssh_port = 22           # default

# Path to SSH private key (required for k3s provisioner)
ssh_private_key_path = "~/.ssh/id_ed25519"

# ClickHouse BYODB
indexer_clickhouse_url      = "https://your-clickhouse-host:8443"
indexer_clickhouse_password = "your-clickhouse-password"

# Webhook shared secret (rindexer → swap-api authentication)
# Generate: openssl rand -hex 32
webhook_secret = "your-webhook-secret"

# (Optional) Cloudflare TLS — uncomment to expose swap-api publicly
# ingress_mode = "cloudflare"
# api_hostname = "api.example.com"
# erpc_hostname = "rpc.example.com"         # optional — only if you want eRPC exposed too
# ingress_cloudflare_origin_cert = <<-EOT
# -----BEGIN CERTIFICATE-----
# ...paste your Cloudflare origin certificate...
# -----END CERTIFICATE-----
# EOT
# ingress_cloudflare_origin_key = <<-EOT
# -----BEGIN PRIVATE KEY-----
# ...paste your Cloudflare origin key...
# -----END PRIVATE KEY-----
# EOT

# (Optional) Override the swap-api image (default: local image via scripts/deploy.sh)
# swap_api_image = "ghcr.io/myorg/swap-api:v1.0.0"

# (Optional) Whale threshold in raw token units (default: 1e18 = 1 token with 18 decimals)
# whale_threshold = "1000000000000000000000"  # 1000 tokens
