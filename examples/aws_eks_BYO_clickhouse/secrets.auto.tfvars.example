# Copy to secrets.auto.tfvars and fill in real values.
# secrets.auto.tfvars is gitignored — never commit secrets.
# Optional when rpc_proxy is enabled — auto-resolves to eRPC internal URL.
# Set only to override with a direct RPC endpoint.
# indexer_rpc_url           = "https://eth-mainnet.g.alchemy.com/v2/your-api-key"
indexer_clickhouse_url      = "https://your-clickhouse-host:8443"
indexer_clickhouse_password = "your-clickhouse-password"
