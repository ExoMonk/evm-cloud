# Copy to secrets.auto.tfvars and fill in real values.
# secrets.auto.tfvars is gitignored — never commit secrets.

# VPS connection (required)
bare_metal_host                 = "100.0.0.0.0"
ssh_private_key_path = "~/.ssh/id_ed25519"

# PostgreSQL BYODB (required)
indexer_postgres_url = "postgres://rindexer:password@your-db-host:5432/rindexer"
