# Copy to secrets.auto.tfvars and fill in real values.
# secrets.auto.tfvars is gitignored — never commit secrets.

# SSH public key for EC2 instance (required)
ssh_public_key = "ssh-ed25519 AAAA..."

# Path to the matching SSH private key (required for k3s provisioner)
ssh_private_key_path = "~/.ssh/id_ed25519"

# CIDRs allowed to reach SSH + k3s API (must include your IP for provisioning)
# Get your IP: curl -s ifconfig.me
k3s_api_allowed_cidrs = ["YOUR_IP/32"]

# ClickHouse BYODB
indexer_clickhouse_url      = "https://your-clickhouse-host:8443"
indexer_clickhouse_password  = "your-clickhouse-password"
