# Copy to secrets.auto.tfvars and fill in your values:
#   cp secrets.auto.tfvars.example secrets.auto.tfvars

# SSH key for EC2 instance (paste public key content)
ssh_public_key = "ssh-ed25519 AAAA... your-email"

# Path to the matching private key (for k3s provisioner SSH)
ssh_private_key_path = "~/.ssh/evm-cloud-e2e"

# Your IP for SSH + k3s API access. Get yours: curl -s ifconfig.me
k3s_api_allowed_cidrs = ["YOUR_IP/32"]
