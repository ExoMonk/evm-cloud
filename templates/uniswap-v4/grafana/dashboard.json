      "title": "Hook Adoption (Pool Count by Hook Address)",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT if(hooks = '0x0000000000000000000000000000000000000000', 'No Hook', substring(hooks, 1, 10) || '...') AS hook_label, count() AS pool_count FROM initialize WHERE network = '${network}' GROUP BY hooks ORDER BY pool_count DESC LIMIT 10",
          "refId": "A",
          "format": 1
        }
      ]
