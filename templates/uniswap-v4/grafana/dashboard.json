      "title": "Swap Volume (Hourly)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT hour AS time, sum(swap_count) AS swaps FROM volume_hourly WHERE network = '${network}' AND hour >= $__fromTime AND hour <= $__toTime GROUP BY hour ORDER BY hour",
          "refId": "A",
          "format": 0
        }
