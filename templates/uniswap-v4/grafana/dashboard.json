          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toDate(block_timestamp) AS time, count() AS pools_created FROM initialize WHERE network = '${network}' AND block_timestamp >= $__fromTime AND block_timestamp <= $__toTime GROUP BY time ORDER BY time",
          "refId": "A",
