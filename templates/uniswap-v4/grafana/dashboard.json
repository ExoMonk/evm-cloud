        "sortBy": [{ "desc": true, "displayName": "swap_count" }]
      },
      "title": "Top Pools by Swap Count",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT s.id AS pool_id, p.currency_0, p.currency_1, p.fee, p.hooks, count() AS swap_count FROM swap s JOIN initialize p ON s.id = p.id AND s.network = p.network WHERE s.network = '${network}' AND s.block_timestamp >= $__fromTime AND s.block_timestamp <= $__toTime GROUP BY s.id, p.currency_0, p.currency_1, p.fee, p.hooks ORDER BY swap_count DESC LIMIT 20",
          "refId": "A",
          "format": 1
        }
      ]
    }
