          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT on_behalf_of AS borrower, count() AS borrow_count, toString(sum(amount)) AS total_borrowed FROM aave_v3_borrows WHERE chain_id = ${chain_id} AND block_timestamp >= $__fromTime AND block_timestamp <= $__toTime GROUP BY on_behalf_of ORDER BY borrow_count DESC LIMIT 20",
