        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT hour AS time, sum(supply_count) AS supplies, sum(withdraw_count) AS withdrawals, sum(borrow_count) AS borrows, sum(repay_count) AS repays FROM aave_v3_utilization_hourly WHERE chain_id = ${chain_id} AND hour >= $__fromTime AND hour <= $__toTime GROUP BY hour ORDER BY hour",
          "refId": "A",
          "format": 0
